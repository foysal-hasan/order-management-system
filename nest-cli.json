{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "assets": [
      "mail/templates/**/*",
      {
        "include": "prisma/generated/**/*",
        "outDir": "./dist/prisma/generated",
        "watchAssets": true
      }
    ],
    "watchAssets": true
  }
}