<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>Email Verification</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #17191f;
      font-family: Arial, Helvetica, sans-serif;
      color: #1f2430;
    "
  >
    <div style="display: none; max-height: 0; overflow: hidden; opacity: 0;">
      Your verification code for <%= process.env.APP_NAME %> is <%= otp %>.
    </div>

    <table
      role="presentation"
      cellpadding="0"
      cellspacing="0"
      border="0"
      width="100%"
      style="background-color: #17191f; margin: 0; padding: 24px 0;"
    >
      <tr>
        <td align="center">
          <table
            role="presentation"
            cellpadding="0"
            cellspacing="0"
            border="0"
            width="100%"
            style="max-width: 640px; margin: 0 auto;"
          >
            <tr>
              <td style="padding: 0 20px;">
                <table
                  role="presentation"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  width="100%"
                  style="
                    background-color: #f7f3ec;
                    border-radius: 24px;
                    border: 1px solid #eadfce;
                  "
                >
                  <tr>
                    <td style="padding: 40px 32px 18px 32px;">
                      <table
                        role="presentation"
                        cellpadding="0"
                        cellspacing="0"
                        border="0"
                        width="100%"
                      >
                        <tr>
                          <td
                            style="
                              font-size: 14px;
                              line-height: 22px;
                              color: #8e7653;
                              font-weight: 700;
                              letter-spacing: 0.6px;
                              text-transform: uppercase;
                            "
                          >
                            Email Verification
                          </td>
                        </tr>
                        <tr>
                          <td
                            style="
                              padding-top: 10px;
                              font-family: Georgia, 'Times New Roman', serif;
                              font-size: 36px;
                              line-height: 42px;
                              color: #21242d;
                              font-weight: 700;
                            "
                          >
                            Confirm your email
                          </td>
                        </tr>
                        <tr>
                          <td
                            style="
                              padding-top: 16px;
                              font-size: 17px;
                              line-height: 28px;
                              color: #535b68;
                            "
                          >
                            Hello <%= name %>,
                          </td>
                        </tr>
                        <tr>
                          <td
                            style="
                              padding-top: 8px;
                              font-size: 17px;
                              line-height: 28px;
                              color: #535b68;
                            "
                          >
                            Use the one-time code below to verify your email
                            address and continue setting up your account.
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>

                  <tr>
                    <td style="padding: 0 32px 12px 32px;">
                      <table
                        role="presentation"
                        cellpadding="0"
                        cellspacing="0"
                        border="0"
                        width="100%"
                        style="
                          background-color: #ffffff;
                          border: 2px solid #e79a29;
                          border-radius: 20px;
                        "
                      >
                        <tr>
                          <td
                            align="center"
                            style="
                              padding: 22px 16px 10px 16px;
                              font-size: 13px;
                              line-height: 18px;
                              text-transform: uppercase;
                              letter-spacing: 1.4px;
                              color: #8e7653;
                              font-weight: 700;
                            "
                          >
                            Your verification code
                          </td>
                        </tr>
                        <tr>
                          <td
                            align="center"
                            style="
                              padding: 0 16px 22px 16px;
                              font-family: 'Courier New', Courier, monospace;
                              font-size: 34px;
                              line-height: 40px;
                              letter-spacing: 10px;
                              color: #1f2430;
                              font-weight: 700;
                            "
                          >
                            <%= otp %>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>

                  <tr>
                    <td style="padding: 8px 32px 32px 32px;">
                      <table
                        role="presentation"
                        cellpadding="0"
                        cellspacing="0"
                        border="0"
                        width="100%"
                      >
                        <tr>
                          <td
                            style="
                              font-size: 15px;
                              line-height: 26px;
                              color: #6a7280;
                            "
                          >
                            Enter this code in the verification screen to
                            continue. If you did not request this, you can
                            safely ignore this email.
                          </td>
                        </tr>
                        <tr>
                          <td
                            style="
                              padding-top: 24px;
                              border-top: 1px solid #e7dccd;
                              font-size: 15px;
                              line-height: 25px;
                              color: #535b68;
                            "
                          >
                            Regards,
                            <br />
                            <span style="color: #21242d; font-weight: 700;">
                              <%= process.env.APP_NAME %> Team
                            </span>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td
                align="center"
                style="
                  padding: 22px 28px 0 28px;
                  font-size: 13px;
                  line-height: 22px;
                  color: #9b9faa;
                "
              >
                This is an automated security email from
                <span style="color: #f2e6d3;"><%= process.env.APP_NAME %></span>.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
